# Indus AI — Environment Variables
# Copy this file to .env and fill in your values

# Groq API Key (get free key at https://console.groq.com)
GROQ_API_KEY=

# Factory Simulator WebSocket URL
SIMULATOR_URL=ws://localhost:8765

# Supabase (optional — system works with in-memory storage as fallback)
SUPABASE_URL=
SUPABASE_ANON_KEY=
